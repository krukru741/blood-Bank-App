<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".presentation.home.HomeFragment">

    <!-- =================== MAP VIEW (Full Screen) =================== -->

    <!-- =================== LIST VIEW =================== -->
    <WebView
        android:id="@+id/web_view_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingTop="24dp"
        android:paddingBottom="120dp"
        android:background="@color/surface" />

    <!-- =================== STATS BAR (Upper Left, Floating) =================== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_legend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#EEFFFFFF">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical">

            <!-- Critical -->
            <View
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_circle_red" />
            <TextView
                android:id="@+id/tv_critical_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="0"
                android:textColor="@color/blood_red"
                android:textStyle="bold"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="#22000000"
                android:layout_marginHorizontal="10dp" />

            <!-- Urgent -->
            <View
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_circle_orange" />
            <TextView
                android:id="@+id/tv_urgent_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="0"
                android:textColor="#E65100"
                android:textStyle="bold"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="#22000000"
                android:layout_marginHorizontal="10dp" />

            <!-- Total -->
            <View
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_circle_green" />
            <TextView
                android:id="@+id/tv_total_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="0"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:textSize="13sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="16dp"
                android:background="#22000000"
                android:layout_marginHorizontal="10dp" />

            <!-- My Type -->
            <View
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_circle_purple" />
            <TextView
                android:id="@+id/tv_my_type_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="0"
                android:textColor="#6A1B9A"
                android:textStyle="bold"
                android:textSize="13sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Request Popup Overlay (Center of screen) ─────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_request_popup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="90dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Banner Image for Hospitals -->
            <ImageView
                android:id="@+id/iv_popup_banner"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <!-- Main Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header: Avatar, Name, Role, Close -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_popup_avatar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_nav_profile"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView"
                        android:scaleType="centerCrop"
                        android:background="#EEEEEE"
                        android:padding="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iv_popup_avatar"
                        android:layout_toStartOf="@+id/btn_popup_close"
                        android:layout_marginStart="12dp"
                        android:layout_centerVertical="true">

                        <TextView
                            android:id="@+id/tv_popup_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Name"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:id="@+id/tv_popup_role"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blood Recipient"
                            android:textSize="13sp"
                            android:textColor="#757575" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_popup_close"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#888888" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- Blood Type (For Requests) -->
                <LinearLayout
                    android:id="@+id/ll_popup_blood_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_blood_drop"
                        app:tint="@color/blood_red" />

                    <TextView
                        android:id="@+id/tv_popup_blood_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="AB+"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="@color/on_surface" />
                </LinearLayout>

                <!-- Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="#888888"
                        android:layout_marginStart="2dp" />

                    <TextView
                        android:id="@+id/tv_popup_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:text="Location Address"
                        android:textSize="14sp"
                        android:textColor="#555555" />
                </LinearLayout>
                
                <!-- Distance (For Hospitals) -->
                <LinearLayout
                    android:id="@+id/ll_popup_distance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_directions"
                        app:tint="#1976D2"
                        android:layout_marginStart="2dp" />

                    <TextView
                        android:id="@+id/tv_popup_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:text="5.2 km away"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1976D2" />
                </LinearLayout>

                <!-- Contact Info (For Hospitals) -->
                <LinearLayout
                    android:id="@+id/ll_popup_contact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="#4CAF50"
                        android:layout_marginStart="2dp" />

                    <TextView
                        android:id="@+id/tv_popup_contact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:text="0917 123 4567"
                        android:textSize="14sp"
                        android:textColor="#4CAF50" />
                </LinearLayout>

                <!-- Action Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_popup_action"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Message"
                    android:backgroundTint="@color/blood_red"
                    app:cornerRadius="8dp"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/white"
                    app:icon="@android:drawable/sym_action_chat"
                    app:iconGravity="textStart"
                    app:iconTint="@color/white" />

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Floating Pill Toggle: Map / List (Bottom Center) ─────────────── -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="35dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:singleSelection="true"
        app:checkedButton="@id/btn_map"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_map"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Map"
            android:textSize="13sp"
            app:icon="@android:drawable/ic_dialog_map"
            app:iconSize="16dp"
            android:paddingHorizontal="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_list"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="List"
            android:textSize="13sp"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconSize="16dp"
            android:paddingHorizontal="16dp" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- ── FAB: Find a Hospital (Bottom Right, above My Location) ────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_find_hospital"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/fab_my_location"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        app:backgroundTint="#1976D2"
        android:src="@android:drawable/ic_menu_mapmode"
        app:tint="@color/white"
        app:elevation="4dp"
        app:borderWidth="0dp"
        app:fabSize="mini"
        android:contentDescription="Find a Hospital" />

    <!-- ── FAB: My Location (Bottom Right) ──────────────────────────── -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_my_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/fab_create_request"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        app:backgroundTint="@color/white"
        android:src="@android:drawable/ic_menu_mylocation"
        app:tint="#666666"
        app:elevation="4dp"
        app:borderWidth="0dp"
        app:fabSize="mini"
        android:contentDescription="My Location" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_create_request"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        app:backgroundTint="@color/blood_red"
        android:src="@drawable/ic_add"
        app:tint="@color/white"
        app:elevation="8dp"
        app:borderWidth="0dp"
        android:contentDescription="Create Request" />

</androidx.constraintlayout.widget.ConstraintLayout>
