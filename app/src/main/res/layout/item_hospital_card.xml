<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="16dp"
    app:cardCornerRadius="@dimen/corner_medium"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke_light"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_hospital_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_menu_hospital"
            app:tint="@color/blood_red"
            android:background="@drawable/bg_circle_light_red"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_hospital_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            tools:text="Philippine General Hospital"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="@id/iv_hospital_icon"
            app:layout_constraintStart_toEndOf="@id/iv_hospital_icon"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_hospital_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="Public (Government)"
            android:textColor="@color/blood_red"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_chip_light_red"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            app:layout_constraintTop_toBottomOf="@id/tv_hospital_name"
            app:layout_constraintStart_toStartOf="@id/tv_hospital_name" />

        <TextView
            android:id="@+id/tv_address"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            tools:text="📍 Taft Ave, Ermita, Manila"
            android:textColor="@color/gray_text"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tv_hospital_type"
            app:layout_constraintStart_toStartOf="@id/tv_hospital_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_contact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="📞 (02) 8554 8400"
            android:textColor="@color/on_surface"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tv_address"
            app:layout_constraintStart_toStartOf="@id/tv_hospital_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_emergency_contact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="🚑 911 / 143"
            android:textColor="@color/urgency_critical"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tv_contact"
            app:layout_constraintStart_toStartOf="@id/tv_hospital_name"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
