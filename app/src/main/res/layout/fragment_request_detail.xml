<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true">

    <!-- Sticky Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blood_red"
        app:elevation="0dp">

        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back" />
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Back to Requests"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:paddingBottom="120dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_header"
                android:paddingBottom="48dp"
                android:paddingTop="16dp">

                <TextView
                    android:id="@+id/tv_blood_type"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_blood_type_badge"
                    android:backgroundTint="@color/surface"
                    android:textColor="@color/blood_red"
                    android:gravity="center"
                    tools:text="O+"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:elevation="4dp" />

                <TextView
                    android:id="@+id/tv_patient_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    tools:text="Maria Santos"
                    android:textColor="@android:color/white"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@id/tv_blood_type"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_hospital"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="32dp"
                    android:layout_marginEnd="32dp"
                    android:gravity="center"
                    tools:text="📍 Surigao del Sur Provincial Hospital"
                    android:textColor="#F5F5F5"
                    android:textSize="15sp"
                    app:layout_constraintTop_toBottomOf="@id/tv_patient_name"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />
                    
                <ImageButton
                    android:id="@+id/btn_edit_request"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@android:color/white"
                    android:visibility="gone"
                    tools:visibility="visible"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="16dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Details Section (Overlapping card) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="-24dp"
                style="@style/Widget.BloodBank.Card.Standard"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp">

                <!-- Flattened Inner Layout using ConstraintLayout -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tv_section_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Urgency &amp; Requirements"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Units Needed Container -->
                    <ImageView
                        android:id="@+id/iv_units"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_blood_drop"
                        app:tint="@color/blood_red"
                        android:layout_marginTop="24dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_section_title"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/iv_urgency" />

                    <TextView
                        android:id="@+id/tv_units"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        tools:text="2 Units"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/iv_units"
                        app:layout_constraintStart_toStartOf="@id/iv_units"
                        app:layout_constraintEnd_toEndOf="@id/iv_units" />

                    <TextView
                        android:id="@+id/tv_units_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Needed"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/tv_units"
                        app:layout_constraintStart_toStartOf="@id/tv_units"
                        app:layout_constraintEnd_toEndOf="@id/tv_units" />

                    <!-- Urgency Container -->
                    <ImageView
                        android:id="@+id/iv_urgency"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_dialog_alert"
                        app:tint="@color/urgency_critical"
                        app:layout_constraintTop_toTopOf="@id/iv_units"
                        app:layout_constraintStart_toEndOf="@id/iv_units"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tv_urgency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        tools:text="CRITICAL"
                        android:textColor="@color/urgency_critical"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/iv_urgency"
                        app:layout_constraintStart_toStartOf="@id/iv_urgency"
                        app:layout_constraintEnd_toEndOf="@id/iv_urgency" />

                    <TextView
                        android:id="@+id/tv_urgency_label_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/tv_urgency"
                        app:layout_constraintStart_toStartOf="@id/tv_urgency"
                        app:layout_constraintEnd_toEndOf="@id/tv_urgency" />

                    <View
                        android:id="@+id/details_divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginTop="32dp"
                        app:layout_constraintTop_toBottomOf="@id/tv_units_label" />
                        
                    <TextView
                        android:id="@+id/tv_notes_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Additional Notes"
                        android:textColor="@color/on_surface"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="24dp"
                        app:layout_constraintTop_toBottomOf="@id/details_divider"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tv_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        tools:text="Patient needs blood for emergency surgery. Please respond immediately if you have a matching blood type."
                        android:textColor="@color/on_surface_variant"
                        android:lineSpacingExtra="6dp"
                        android:textSize="16sp"
                        app:layout_constraintTop_toBottomOf="@id/tv_notes_title" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Action Area (Bottom) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/white"
        android:elevation="16dp"
        android:padding="24dp">

        <!-- For Donor: Accept Request -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accept_request"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="@color/blood_red"
            android:text="🩸 I WANT TO DONATE"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible"
            app:cornerRadius="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- For MATCHED status: Contact Options -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_contact_donor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_matched_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You are matched to this patient!"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_call_donor"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:text="Call"
                android:textColor="@color/blood_red"
                app:strokeColor="@color/blood_red"
                app:icon="@android:drawable/ic_menu_call"
                app:iconTint="@color/blood_red"
                app:cornerRadius="30dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_matched_status"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_text_donor" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_text_donor"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginStart="8dp"
                android:text="Message"
                android:backgroundTint="@color/blood_red"
                app:icon="@android:drawable/ic_dialog_email"
                app:cornerRadius="30dp"
                app:layout_constraintTop_toTopOf="@id/btn_call_donor"
                app:layout_constraintBottom_toBottomOf="@id/btn_call_donor"
                app:layout_constraintStart_toEndOf="@id/btn_call_donor"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
