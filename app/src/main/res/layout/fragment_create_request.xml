<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_create_request"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_variant"
    tools:context=".presentation.request.CreateRequestFragment">

    <!-- ── App Bar & Stepper Header ─────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_auth"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Create Request"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextColor="@color/white"
            app:navigationIconTint="@color/white" />

        <LinearLayout
            android:id="@+id/layout_stepper_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:paddingHorizontal="16dp"
            android:background="@color/surface">

        <TextView
            android:id="@+id/tv_step_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. Details"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/blood_red" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="8dp"
            android:background="@color/stroke_light" />

        <TextView
            android:id="@+id/tv_step_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2. Location"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/icon_gray" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="8dp"
            android:background="@color/stroke_light" />

        <TextView
            android:id="@+id/tv_step_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3. Review"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/icon_gray" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:layout_marginBottom="80dp"
        android:fillViewport="true">

        <ViewFlipper
            android:id="@+id/view_flipper_steps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- STEP 1: Details -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/corner_large"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface">
                
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                <TextView
                    android:id="@+id/tv_urgency_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gaano ka-urgent kailangan? (Urgency)"
                    android:textColor="@color/gray_text"
                    android:textSize="14sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_group_urgency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btn_urgency_normal"
                    app:layout_constraintTop_toBottomOf="@id/tv_urgency_label">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_urgency_normal"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:paddingHorizontal="0dp"
                        android:text="🟢 Normal" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_urgency_urgent"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:paddingHorizontal="0dp"
                        android:text="🟠 Urgent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_urgency_critical"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:paddingHorizontal="0dp"
                        android:text="🔴 Critical" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_blood_type"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:hint="Anong blood type ang kailangan?"
                    app:layout_constraintTop_toBottomOf="@id/toggle_group_urgency">
                    <AutoCompleteTextView
                        android:id="@+id/acv_blood_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="none"
                        tools:ignore="LabelFor" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_units"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Ilang bag ng dugo? (How many bags?)"
                    app:suffixText="bags"
                    app:helperText="1 bag = 1 unit (~473 mL)"
                    app:layout_constraintTop_toBottomOf="@id/til_blood_type">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_units"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="number"
                        android:text="1"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STEP 2: Location -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/corner_large"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface">
                
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_hospital"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Pangalan ng Ospital (Hospital)"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_hospital"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="textCapWords"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tv_map_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Pindutin ang map o gamitin ang GPS"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/til_hospital" />
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_use_location"
                    style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp"
                    android:text="Use GPS"
                    app:icon="@drawable/ic_my_location"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/btn_pick_map"
                    app:layout_constraintTop_toBottomOf="@id/tv_map_hint" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pick_map"
                    style="@style/Widget.Material3.Button.TonalButton.Icon"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:minHeight="48dp"
                    android:text="Map"
                    app:icon="@drawable/ic_map"
                    app:layout_constraintStart_toEndOf="@id/btn_use_location"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_map_hint" />

                <!-- Error Fallback Layout for PSGC -->
                <LinearLayout
                    android:id="@+id/layout_psgc_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="16dp"
                    android:background="#FFF5F5"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/btn_use_location">
                    
                    <TextView
                        android:id="@+id/tv_psgc_error_msg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mahina ang internet, hindi ma-load ang listahan ng lokasyon."
                        android:textColor="@color/blood_red"
                        android:textSize="14sp"
                        android:textAlignment="center" />
                        
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_retry_psgc"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Retry (Subukan Ulit)" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_province"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Probinsya"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_psgc_error">
                    <AutoCompleteTextView
                        android:id="@+id/et_province"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_city"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Siyudad"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_province">
                    <AutoCompleteTextView
                        android:id="@+id/et_city"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_barangay"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Barangay"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_city">
                    <AutoCompleteTextView
                        android:id="@+id/et_barangay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_street"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Street (Opsiyonal)"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/til_barangay">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_street"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="textCapWords"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STEP 3: Review & Submit -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/corner_large"
                app:strokeColor="@color/stroke_light"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface">
                
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_contact"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contact Number ng Pamilya"
                    app:helperText="Dito kayo tatawagan ng magdo-donate"
                    app:layout_constraintTop_toTopOf="parent">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_contact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="phone"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_notes"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:hint="Iba pang detalye (Opsiyonal)"
                    app:counterEnabled="true"
                    app:counterMaxLength="200"
                    app:layout_constraintTop_toBottomOf="@id/til_contact">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="3"
                        android:maxLines="5"
                        android:maxLength="200" />
                </com.google.android.material.textfield.TextInputLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </ViewFlipper>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Back"
            android:visibility="invisible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/blood_red"
            android:text="Next"
            android:textColor="@color/white" />
            
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_submit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="16dp"
            android:visibility="gone"
            app:indicatorColor="@color/blood_red" />
    </LinearLayout>

    <!-- Full screen Map Picker Overlay -->
    <FrameLayout
        android:id="@+id/layout_map_picker"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@color/white"
        android:elevation="12dp">
        
        <WebView
            android:id="@+id/web_view_map_picker"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
            
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_location_on"
            app:tint="@color/blood_red" />
            
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_location"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="bottom"
            android:layout_margin="24dp"
            android:text="Confirm Location"
            android:backgroundTint="@color/blood_red" />
            
        <ImageButton
            android:id="@+id/btn_close_map"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:layout_margin="16dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#444444" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
