<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".presentation.profile.ProfileFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Profile Header (gradient bg) ──────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_auth"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="48dp"
                android:paddingHorizontal="24dp">

                <!-- Avatar placeholder -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    android:background="@color/white"
                    android:padding="20dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.CircleImageView" />

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="Maria Santos" />

                <TextView
                    android:id="@+id/tv_profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    tools:text="maria.santos@email.com" />

                <!-- Blood type + Role badges -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_blood_type_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_blood_type_badge"
                        android:gravity="center"
                        android:padding="8dp"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:minWidth="48dp"
                        tools:text="O+" />

                    <TextView
                        android:id="@+id/tv_role_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_chip_filter"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:textColor="@android:color/black"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="🩸 Donor" />

                </LinearLayout>

                <!-- Verified Donor Badge (donors only) -->
                <LinearLayout
                    android:id="@+id/ll_verified_donor_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="#40FFD700"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏅 VERIFIED DONOR"
                        android:textColor="#FFD700"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Donor ID row (donors only) -->
                <TextView
                    android:id="@+id/tv_donor_id_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="Donor ID: BBANK-000001" />

                <!-- View Donor Card Button (donors only) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_donor_card"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="14dp"
                    android:text="🪪  View My Donor Card"
                    android:textSize="13sp"
                    android:visibility="gone"
                    app:backgroundTint="#CC000000"
                    app:strokeColor="#80FFFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="20dp"
                    android:textColor="@color/white"
                    style="?attr/materialButtonOutlinedStyle" />

            </LinearLayout>

            <!-- ── Stats Card ─────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="3">

                    <!-- Stat 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_stat1_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/blood_red"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="5" />
                        <TextView
                            android:id="@+id/tv_stat1_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            tools:text="Donations" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E0E0E0" />

                    <!-- Stat 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_stat2_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/blood_red"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="3" />
                        <TextView
                            android:id="@+id/tv_stat2_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            tools:text="Lives Saved" />
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E0E0E0" />

                    <!-- Stat 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tv_stat3_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/success_green"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="✓" />
                        <TextView
                            android:id="@+id/tv_stat3_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:gravity="center"
                            android:textColor="#757575"
                            android:textSize="11sp"
                            tools:text="Eligible Now" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Donor Availability Toggle (Donors Only) ────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_availability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:visibility="gone">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Available to Donate"
                            android:textColor="@color/on_surface"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Let recipients know you can donate right now."
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_available"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Donor Badges (Donors Only) ─────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_badges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Donor Achievements"
                        android:textColor="@color/blood_red"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            
                            <!-- Badge 1: Bronze -->
                            <LinearLayout
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="16dp">
                                <ImageView
                                    android:id="@+id/iv_badge_bronze"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@android:drawable/btn_star_big_on"
                                    app:tint="#CD7F32" /> <!-- Bronze color -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Starter"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1 Donation"
                                    android:textSize="9sp"
                                    android:textColor="#888888" />
                            </LinearLayout>

                            <!-- Badge 2: Silver -->
                            <LinearLayout
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:layout_marginEnd="16dp">
                                <ImageView
                                    android:id="@+id/iv_badge_silver"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@android:drawable/btn_star_big_off"
                                    app:tint="#C0C0C0" /> <!-- Silver color -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Life Saver"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="#888888"
                                    android:layout_marginTop="4dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5 Donations"
                                    android:textSize="9sp"
                                    android:textColor="#888888" />
                            </LinearLayout>

                            <!-- Badge 3: Gold -->
                            <LinearLayout
                                android:layout_width="80dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center">
                                <ImageView
                                    android:id="@+id/iv_badge_gold"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@android:drawable/btn_star_big_off"
                                    app:tint="#FFD700" /> <!-- Gold color -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Hero"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:textColor="#888888"
                                    android:layout_marginTop="4dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="10 Donations"
                                    android:textSize="9sp"
                                    android:textColor="#888888" />
                            </LinearLayout>
                            
                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Complete Profile Prompt (For Base Users) ───────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_complete_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3E0"
                app:strokeColor="#FFE0B2"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete Your Profile"
                        android:textColor="#E65100"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Become a donor or verify your details to fully utilize the blood bank."
                        android:textColor="#EF6C00"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_complete_profile"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Become a Donor"
                        android:textColor="#E65100" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Info Section ───────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal Information"
                        android:textColor="@color/on_surface"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Phone -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginVertical="6dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_call" android:tint="@color/blood_red" android:contentDescription="Phone" />
                        <TextView android:id="@+id/tv_phone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:textColor="@color/on_surface" android:textSize="14sp" tools:text="+63 912 345 6789" />
                    </LinearLayout>

                    <!-- Location -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginVertical="6dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_mapmode" android:tint="@color/blood_red" android:contentDescription="Location" />
                        <TextView android:id="@+id/tv_city" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:textColor="@color/on_surface" android:textSize="14sp" tools:text="Barobo, Surigao del Sur" />
                    </LinearLayout>

                    <!-- Weight (donors only) -->
                    <LinearLayout android:id="@+id/row_weight" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginVertical="6dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_info_details" android:tint="@color/blood_red" android:contentDescription="Weight" />
                        <TextView android:id="@+id/tv_weight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:textColor="@color/on_surface" android:textSize="14sp" tools:text="65 kg" />
                    </LinearLayout>

                    <!-- Last donation (donors only) -->
                    <LinearLayout android:id="@+id/row_last_donation" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginVertical="6dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_today" android:tint="@color/blood_red" android:contentDescription="Last donation" />
                        <TextView android:id="@+id/tv_last_donation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:textColor="@color/on_surface" android:textSize="14sp" tools:text="Last donated: Jan 15, 2025" />
                    </LinearLayout>

                    <!-- Email verification status -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginVertical="6dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_dialog_email" android:tint="@color/blood_red" android:contentDescription="Email" />
                        <TextView android:id="@+id/tv_verification_status" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:textColor="@color/on_surface" android:textSize="14sp" tools:text="✅ Email Verified" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Action Buttons ─────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit_profile"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:text="Edit Profile"
                android:textColor="@color/blood_red"
                app:strokeColor="@color/blood_red"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
