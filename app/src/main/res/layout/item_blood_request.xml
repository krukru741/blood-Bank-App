<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_blood_request"
    style="@style/Widget.BloodBank.Card.Standard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Blood Type Badge -->
        <TextView
            android:id="@+id/tv_blood_type"
            android:layout_width="48dp"
            android:layout_height="48dp"
            tools:text="A+"
            android:gravity="center"
            android:background="@drawable/bg_blood_type_badge"
            android:backgroundTint="@color/blood_red"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Requester Name -->
        <TextView
            android:id="@+id/tv_requester_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            tools:text="Maria Santos"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/tv_blood_type"
            app:layout_constraintTop_toTopOf="@id/tv_blood_type"
            app:layout_constraintEnd_toStartOf="@id/tv_time_ago" />

        <!-- Time Posted -->
        <TextView
            android:id="@+id/tv_time_ago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="2h ago"
            android:textColor="@color/gray_text"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_requester_name"
            app:layout_constraintBottom_toBottomOf="@id/tv_requester_name" />

        <!-- Hospital Info -->
        <TextView
            android:id="@+id/tv_hospital"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="📍 Surigao del Sur Provincial Hospital"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="@id/tv_requester_name"
            app:layout_constraintTop_toBottomOf="@id/tv_requester_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Description (Optional) -->
        <TextView
            android:id="@+id/tv_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            tools:text="Patient needs blood for emergency surgery scheduled tomorrow morning."
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_blood_type" />

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#EEEEEE"
            app:layout_constraintTop_toBottomOf="@id/tv_description" />

        <!-- Units -->
        <TextView
            android:id="@+id/tv_units"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:background="@drawable/bg_chip_filter"
            android:paddingHorizontal="12dp"
            tools:text="2 units"
            android:textColor="@color/blood_red"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Urgency Label -->
        <TextView
            android:id="@+id/tv_urgency_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            tools:text="⚠ CRITICAL"
            android:textColor="@color/urgency_critical"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tv_units"
            app:layout_constraintTop_toTopOf="@id/tv_units"
            app:layout_constraintBottom_toBottomOf="@id/tv_units" />

        <!-- Respond Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_respond"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Respond"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="@color/blood_red"
            android:textColor="@color/white"
            app:cornerRadius="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_units"
            app:layout_constraintBottom_toBottomOf="@id/tv_units" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
