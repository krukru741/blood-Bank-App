<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — Fully Migrated to Material 3 -->
    <style name="Theme.BloodBank" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Palette -->
        <item name="colorPrimary">@color/blood_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/blood_red_container</item>
        <item name="colorOnPrimaryContainer">@color/on_blood_red_container</item>
        
        <!-- Secondary / Accent Palette -->
        <item name="colorSecondary">@color/accent_coral</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/accent_coral_container</item>
        <item name="colorOnSecondaryContainer">@color/on_accent_coral_container</item>

        <!-- Typography & Surface Readability -->
        <item name="android:windowBackground">@color/off_white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Status Bar Hardware Control -->
        <item name="android:statusBarColor">@color/blood_red_dark</item>
        <item name="android:windowLightStatusBar">false</item> <!-- Puti ang icons sa ibabaw kay ngitngit ang background -->
    </style>

    <!-- Splash screen theme — pabilin nga intact ug paspas -->
    <style name="Theme.BloodBank.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/blood_red</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.BloodBank</item>
    </style>

    <!-- Circle shape for profile avatar ShapeableImageView -->
    <style name="ShapeAppearance.App.CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>